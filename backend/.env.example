# Environment Variables - Backend
# Copy this file to .env and fill in your values

# Database - Azure PostgreSQL
DATABASE_URL="postgresql://USERNAME:PASSWORD@SERVER.postgres.database.azure.com:5432/teamtracker?sslmode=require"

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=YOUR_ACCOUNT;AccountKey=YOUR_KEY;EndpointSuffix=core.windows.net"
AZURE_STORAGE_ACCOUNT_NAME="your-storage-account-name"

# Blob Containers
AZURE_CONTAINER_CERTIFICATES="certificates"
AZURE_CONTAINER_PROFILE_IMAGES="profile-images"
AZURE_CONTAINER_PROJECT_DOCS="project-documents"
AZURE_CONTAINER_REPORTS="reports"

# Server
PORT=3001
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:5173"
