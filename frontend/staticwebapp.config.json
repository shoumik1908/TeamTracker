{
  "routes": [
    {
      "route": "/api/*",
      "methods": ["GET", "POST", "PUT", "PATCH", "DELETE"],
      "backendUri": "https://YOUR-APP-SERVICE.azurewebsites.net/api/*"
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/_frameworks/*", "/assets/*"]
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html",
      "statusCode": 200
    }
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY",
    "Content-Security-Policy": "default-src https: 'unsafe-inline' 'unsafe-eval'; img-src * data: blob:",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  },
  "mimeTypes": {
    ".json": "application/json"
  }
}
